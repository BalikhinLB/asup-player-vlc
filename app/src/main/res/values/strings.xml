    <string name="help_close">Close</string>
    <string name="help_open_video_title">Open video</string>
    <string name="help_open_video_body">Use Find video on the home screen or the folder button in the player. The same menu shows recent files.</string>
    <string name="help_playback_title">Playback</string>
    <string name="help_playback_body">Tap the video to show or hide controls. Use play/pause and the seek bar. Double-tap the left or right half to jump to the previous or next subtitle phrase.</string>
    <string name="help_subtitle_tracks_title">Subtitle tracks</string>
    <string name="help_subtitle_tracks_body">Open Settings → Subtitles to choose an embedded track or load an external SRT file. Use the eye button to show or hide subtitles.</string>
    <string name="help_subtitle_tap_title">Subtitle actions</string>
    <string name="help_subtitle_tap_body">Open Settings → Subtitles → Tap actions. Single tap works with the tapped word, double tap and long press work with the full phrase.</string>
    <string name="help_gestures_title">Gestures</string>
    <string name="help_gestures_body">Swipe up/down on the left side to adjust brightness, on the right side to adjust volume. Swipe left on the left side to rewind 10 seconds, swipe right on the right side to skip forward 10 seconds.</string>
